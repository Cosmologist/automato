#!/usr/bin/env python3
"""List AmneziaWG client profiles"""

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib.cli import CLI

CONFIG_DIR = Path("/etc/amnezia/amneziawg")


def profiles(config_dir: Path | str = CONFIG_DIR) -> list[dict]:
    """List AmneziaWG profiles from a config directory.

    Args:
        config_dir: Directory containing .conf files
    """
    config_dir = Path(config_dir)
    result = []
    for conf in sorted(config_dir.glob("*.conf")):
        text = conf.read_text()
        has_interface = False
        has_peer = False
        endpoint = ""

        section = None
        for line in text.splitlines():
            stripped = line.strip()
            if stripped.startswith("[Interface]"):
                section = "interface"
                has_interface = True
            elif stripped.startswith("[Peer]"):
                section = "peer"
                if not has_peer:
                    has_peer = True
            elif section == "peer" and not endpoint:
                if stripped.lower().startswith("endpoint"):
                    endpoint = stripped.split("=", 1)[1].strip()

        result.append({
            "name": conf.stem,
            "path": str(conf),
            "peer": endpoint,
            "valid": has_interface and has_peer,
        })
    return result


def main():
    cli = CLI(version="1.0.0", prog=__file__, icon="Ⓐ", description="List AmneziaWG client profiles")

    @cli.command(default=True)
    def show() -> list[dict]:
        """List all AmneziaWG profiles"""
        return profiles()

    cli.run()


if __name__ == "__main__":
    main()
