#!/usr/bin/env python3
"""AmneziaWG client manager"""

from __future__ import annotations

import configparser
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib.cli import CLI

CONFIG_DIR = Path("/etc/amnezia/amneziawg")


def profiles(config_dir: Path | str = CONFIG_DIR) -> list[dict]:
    """List AmneziaWG profiles.

    Args:
        config_dir: Directory containing .conf files ["/etc/amnezia/amneziawg"]
    """
    config_dir = Path(config_dir)
    result = []
    for conf in sorted(config_dir.glob("*.conf")):
        parser = configparser.ConfigParser(strict=False, allow_no_value=True)
        parser.read(conf)
        valid = parser.has_section("Interface") and parser.has_section("Peer")
        endpoint = parser.get("Peer", "Endpoint", fallback="") if valid else ""
        result.append({
            "name": conf.stem,
            "path": str(conf),
            "peer": endpoint,
            "valid": valid,
        })
    return result


def main():
    cli = CLI(version="1.0.0", prog=__file__, icon="Ⓐ", description="List AmneziaWG client profiles")

    @cli.command(default=True)
    def show() -> list[dict]:
        """List all AmneziaWG profiles"""
        return profiles()

    cli.run()


if __name__ == "__main__":
    main()
