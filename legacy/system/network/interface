#!/usr/bin/env python3
"""Show network interface info"""

from __future__ import annotations

import json
import sys
from pathlib import Path
from typing import Literal, get_type_hints

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
from lib.cli import CLI, _literal_choices


def _resolve_iface(cli, name: str) -> str:
    if name == "default":
        output = cli.require_output(["ip", "route", "show", "default"])
        return output.splitlines()[0].split()[4]
    return name


def main():
    cli = CLI(version="1.1.0", prog=__file__, description="Show network interface info")

    @cli.command(default=True)
    def show(name: str, *fields: Literal["name", "status", "mtu", "ip", "gateway"]) -> dict:
        """Show interface details

        Args:
            name: Interface name or "default"
            fields: Fields to show (default: all)
        """
        hints = get_type_hints(show)
        choices = _literal_choices(hints.get("fields"))
        requested = set(fields) if fields else set(choices)

        resolved = _resolve_iface(cli, name)
        data = cli.exec(["ip", "-j", "addr", "show", resolved])
        entries = json.loads(data.stdout)
        if not entries:
            raise RuntimeError(f"Interface '{resolved}' not found")
        entry = entries[0]

        out: dict[str, object] = {}
        if "name" in requested:
            out["name"] = entry["ifname"]
        if "status" in requested:
            out["status"] = "UP" if "UP" in entry.get("flags", []) else "DOWN"
        if "mtu" in requested:
            out["mtu"] = entry.get("mtu")
        if "ip" in requested or "gateway" in requested:
            inet4 = [a for a in entry.get("addr_info", []) if a.get("family") == "inet"]
            if len(inet4) != 1:
                raise RuntimeError(
                    f"Expected exactly 1 IPv4 address on {resolved}, got {len(inet4)}"
                )
            if "ip" in requested:
                out["ip"] = f"{inet4[0]['local']}/{inet4[0]['prefixlen']}"
            if "gateway" in requested:
                gw_out = cli.require_output(["ip", "route", "show", "default", "dev", resolved])
                gw_parts = gw_out.split()
                out["gateway"] = gw_parts[2] if len(gw_parts) >= 3 else None
        return out

    cli.run()


if __name__ == "__main__":
    main()
