#!/usr/bin/env python3
"""Show network interface info"""

from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
from lib.cli import CLI, default as default_dec


VALID_FIELDS = {"name", "status", "mtu", "ip", "gateway"}


class Interface(CLI):
    _arg_labels = {"name": "name|default", "fields": "name|status|mtu|ip|gateway"}
    _output_fields = ["name", "status", "mtu", "ip", "gateway"]
    _version = "1.0.0"

    def _resolve_iface(self, name: str) -> str:
        if name == "default":
            result = self._exec(["ip", "route", "show", "default"])
            lines = result.stdout.strip().splitlines()
            if not lines:
                raise RuntimeError("No default route found")
            return lines[0].split()[4]
        return name

    @default_dec
    def show(self, name: str, *fields: str) -> dict:
        """Show interface details

        Args:
            name: Interface name or "default"
            fields: Fields to show (name, status, mtu, ip, gateway). Show all if empty.
        """
        requested = set(fields) if fields else VALID_FIELDS
        bad = requested - VALID_FIELDS
        if bad:
            raise RuntimeError(f"Unknown field(s): {', '.join(sorted(bad))}")

        resolved = self._resolve_iface(name)
        data = self._exec(["ip", "-j", "addr", "show", resolved])
        entries = json.loads(data.stdout)
        if not entries:
            raise RuntimeError(f"Interface '{resolved}' not found")
        entry = entries[0]

        out: dict[str, object] = {}
        if "name" in requested:
            out["name"] = entry["ifname"]
        if "status" in requested:
            out["status"] = "UP" if "UP" in entry.get("flags", []) else "DOWN"
        if "mtu" in requested:
            out["mtu"] = entry.get("mtu")
        if "ip" in requested or "gateway" in requested:
            inet4 = [a for a in entry.get("addr_info", []) if a.get("family") == "inet"]
            if len(inet4) != 1:
                raise RuntimeError(
                    f"Expected exactly 1 IPv4 address on {resolved}, got {len(inet4)}"
                )
            if "ip" in requested:
                out["ip"] = f"{inet4[0]['local']}/{inet4[0]['prefixlen']}"
            if "gateway" in requested:
                gw = self._exec(["ip", "route", "show", "default", "dev", resolved])
                gw_parts = gw.stdout.strip().split()
                out["gateway"] = gw_parts[2] if len(gw_parts) >= 3 else None
        return out


if __name__ == "__main__":
    Interface.run()
