#!/usr/bin/env python3
"""List APT repositories"""

from __future__ import annotations

import re
import sys
import urllib.request
from pathlib import Path
from urllib.parse import urlparse

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
from lib.cli import CLI

import aptsources.sourceslist
from aptsources.distro import get_distro

# Standard APT suite aliases — not tied to any specific distro
_ALIASES = {"stable", "testing", "unstable", "oldstable", "sid", "experimental", "devel"}


def _parse_pins() -> list[dict]:
    """Parse pin rules from /etc/apt/preferences and preferences.d/."""
    paths = ["/etc/apt/preferences"]
    pref_dir = Path("/etc/apt/preferences.d")
    if pref_dir.is_dir():
        paths += [str(p) for p in pref_dir.iterdir() if p.is_file()]

    pins: list[dict] = []
    for path in paths:
        try:
            content = Path(path).read_text()
        except OSError:
            continue

        for block in re.split(r"\n\n+", content):
            pkg = pin = None
            priority = None
            for line in block.splitlines():
                line = line.strip()
                if line.startswith("#") or not line:
                    continue
                if line.lower().startswith("package:"):
                    pkg = line.split(":", 1)[1].strip()
                elif line.lower().startswith("pin:"):
                    pin = line.split(":", 1)[1].strip()
                elif line.lower().startswith("pin-priority:"):
                    try:
                        priority = int(line.split(":", 1)[1].strip())
                    except ValueError:
                        pass
            if pin and priority is not None:
                pins.append({"package": pkg, "pin": pin, "priority": priority})

    return pins


def _match_pin(uri: str, pins: list[dict]) -> tuple[bool, int | None]:
    """Check if any pin rule matches the given URI by origin hostname."""
    parsed = urlparse(uri)
    host = parsed.hostname
    if not host:
        return False, None

    for p in pins:
        pin_str = p["pin"]
        m = re.match(r"origin\s+(.+)", pin_str, re.IGNORECASE)
        if m and m.group(1).strip().lower() == host.lower():
            return True, p["priority"]

    return False, None


def _url_matches_template(url: str, tmpl) -> bool:
    """Check if a URL matches a template's base_uri or match_uri pattern.

    Handles exact base_uri matches as well as mirror URL matching via
    the template's match_uri regex pattern.
    """
    url_norm = url.rstrip("/")

    tmpl_uri = tmpl.base_uri
    if not tmpl_uri and tmpl.parents:
        tmpl_uri = tmpl.parents[0].base_uri
    if tmpl_uri and url_norm == tmpl_uri.rstrip("/"):
        return True
    if tmpl.match_uri and re.search(tmpl.match_uri, url):
        return True

    return False


def _get_official_suites(sl, os_distro) -> dict[str, set[str]]:
    """Build a map of base_uri -> suite names from distribution templates.

    Uses the distribution's template metadata to discover all official
    suites (release, updates, security, etc.) without hardcoding any
    distribution-specific values.
    """
    codename = os_distro.codename
    suites_by_uri: dict[str, set[str]] = {}

    for tmpl in sl.matcher.templates:
        if tmpl.distribution != os_distro.id or not tmpl.official:
            continue
        if not (tmpl.name == codename or tmpl.name.startswith(f"{codename}-") or tmpl.name in _ALIASES):
            continue

        uri = tmpl.base_uri
        if not uri and tmpl.parents:
            uri = tmpl.parents[0].base_uri
        if not uri:
            continue

        uri = uri.rstrip("/")
        suites_by_uri.setdefault(uri, set()).add(tmpl.name)

    return suites_by_uri


def _resolve_suite_url(suite: str) -> str:
    """Find the repository URL for a given suite.

    Uses template metadata and configured sources to discover which
    repository provides the given suite. Errors if not found or ambiguous.

    Returns:
        Repository base URL (without /dists/… suffix).

    Raises:
        ValueError: suite not found or found in multiple repositories.
    """
    sl = aptsources.sourceslist.SourcesList(deb822=True)
    os_distro = get_distro()
    os_distro.get_sources(sl)
    suites_by_uri = _get_official_suites(sl, os_distro)

    candidates: set[str] = set()

    for uri, suites in suites_by_uri.items():
        if suite in suites:
            candidates.add(uri)

    for entry in sl.exploded_list():
        if not entry.type or not entry.uri:
            continue
        if not entry.uri.startswith(("http://", "https://")):
            continue
        if entry.dist == suite:
            candidates.add(entry.uri)

    if not candidates:
        raise ValueError(f"Suite '{suite}' not found in any known repository")
    if len(candidates) > 1:
        raise ValueError(f"Suite '{suite}' is ambiguous — found in multiple repositories: {', '.join(sorted(candidates))}")

    return candidates.pop()


def _list_components(suite: str, url: str | None = None) -> list[str]:
    """List components available for a given suite in a repository.

    Fetches the Release file from the repository and extracts the
    Components field.

    Args:
        suite: Suite name (e.g. unstable, trixie, noble).
        url: Repository base URL (without /dists/…). Auto-detected if not given.

    Returns:
        Sorted list of component names (e.g. main, contrib, non-free).
    """
    if url is None:
        url = _resolve_suite_url(suite)

    release_url = f"{url.rstrip('/')}/dists/{suite}/Release"

    try:
        with urllib.request.urlopen(release_url, timeout=10) as resp:
            content = resp.read().decode("utf-8", errors="replace")
    except Exception as e:
        raise RuntimeError(f"Failed to fetch Release file from {release_url}: {e}")

    components_set: set[str] = set()
    for line in content.splitlines():
        line_s = line.strip()
        if line_s.startswith("Components:"):
            parts = line_s.split(":", 1)[1].strip()
            for comp in parts.split():
                components_set.add(comp)
            break

    if not components_set:
        raise ValueError(f"No Components field found in Release file at {release_url}")

    return sorted(components_set)


def summary() -> list[dict]:
    """List all APT repositories with all available suites.
 
    Uses distribution template metadata to discover official repositories
    and their suites dynamically, without hardcoding any distribution-
    specific values.
 
    Returns:
        List of dicts with suite, url, active_components, available_components,
        active, pin-priority.
    """
    sl = aptsources.sourceslist.SourcesList(deb822=True)
    pins = _parse_pins()

    os_distro = get_distro()
    os_distro.get_sources(sl)

    suites_by_uri = _get_official_suites(sl, os_distro)

    configured: set[tuple[str, str]] = set()
    urls: set[str] = set()
    components_by_key: dict[tuple[str, str], set[str]] = {}

    for entry in sl.exploded_list():
        if not entry.type or not entry.uri:
            continue
        if not entry.uri.startswith(("http://", "https://")):
            continue
        urls.add(entry.uri)
        configured.add((entry.uri, entry.dist))
        if entry.comps:
            components_by_key.setdefault((entry.uri, entry.dist), set()).update(entry.comps)

    repos: list[dict] = []
    seen: set[tuple[str, str]] = set()
    _cache_avail: dict[tuple[str, str], list[str] | None] = {}

    def _get_available(suite_name: str, url: str) -> list[str] | None:
        key = (url, suite_name)
        if key not in _cache_avail:
            try:
                _cache_avail[key] = _list_components(suite_name, url)
            except Exception:
                _cache_avail[key] = None
        return _cache_avail[key]

    for url in sorted(urls):
        _, pin_priority = _match_pin(url, pins)

        official_suites: set[str] | None = None
        url_norm = url.rstrip("/")

        if url_norm in suites_by_uri:
            official_suites = suites_by_uri[url_norm]
        else:
            for tmpl in sl.matcher.templates:
                if tmpl.distribution != os_distro.id or not tmpl.official:
                    continue
                if _url_matches_template(url, tmpl):
                    uri = tmpl.base_uri
                    if not uri and tmpl.parents:
                        uri = tmpl.parents[0].base_uri
                    if uri:
                        official_suites = suites_by_uri.get(uri.rstrip("/"))
                        break

        if official_suites:
            for suite_name in sorted(official_suites):
                key = (url, suite_name)
                if key in seen:
                    continue
                seen.add(key)
                comps = components_by_key.get(key, set())
                avail = _get_available(suite_name, url)
                repos.append({
                    "suite": suite_name,
                    "url": url,
                    "active_components": ",".join(sorted(comps)) if comps else None,
                    "available_components": ",".join(avail) if avail else None,
                    "active": key in configured,
                    "pin-priority": pin_priority,
                })
        else:
            for entry in sl.exploded_list():
                if not entry.type or entry.uri != url:
                    continue
                key = (url, entry.dist)
                if key in seen:
                    continue
                seen.add(key)
                comps = entry.comps or []
                avail = _get_available(entry.dist, url)
                repos.append({
                    "suite": entry.dist,
                    "url": url,
                    "active_components": ",".join(sorted(comps)) if comps else None,
                    "available_components": ",".join(avail) if avail else None,
                    "active": True,
                    "pin-priority": pin_priority,
                })

    return repos


def main():
    cli = CLI(version="2.2.0", prog=__file__, description="List APT repositories")

    @cli.command(default=True)
    def summary_cmd() -> list[dict]:
        """Show all APT repositories with all available suites"""
        repos = summary()
        # double sort: primary by url, secondary by suite
        repos.sort(key=lambda r: (r["url"], r["suite"]))
        return repos

    @cli.command()
    def components(suite: str, url: str | None = None) -> list[str]:
        """List components available for a given suite in a repository

        Args:
            suite: Suite name
            url: Repository base URL
        """
        return _list_components(suite, url)

    cli.run()


if __name__ == "__main__":
    main()
