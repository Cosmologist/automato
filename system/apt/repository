#!/usr/bin/env python3
"""List APT repositories"""

from __future__ import annotations

import distro
import re
import sys
import urllib.request
import urllib.error
from html.parser import HTMLParser
from pathlib import Path
from urllib.parse import urlparse

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
from lib.cli import CLI

import aptsources.sourceslist


class _DirListParser(HTMLParser):
    """Parse Apache/Nginx directory listing HTML to extract folder names."""

    def __init__(self):
        super().__init__()
        self.entries: list[str] = []

    def handle_starttag(self, tag, attrs):
        if tag == "a":
            for attr, val in attrs:
                if attr == "href" and val and not val.startswith("?") and not val.startswith("/"):
                    name = val.rstrip("/")
                    if name and name != "..":
                        self.entries.append(name)


def _derive_name(uri: str) -> str:
    """Derive a short name from repository URI."""
    parsed = urlparse(uri)

    # cdrom: sources — non-network, return simple name
    if parsed.scheme == "cdrom":
        return "cdrom"

    host = parsed.hostname or ""
    path = parsed.path.strip("/")

    if "launchpad" in host and path:
        parts = [p for p in path.split("/") if p not in ("ubuntu", "ppa")]
        if len(parts) >= 2:
            return f"{parts[0]}-{parts[1]}"
        if parts:
            return parts[0]
    if "cursor" in host:
        return "cursor"
    if "google" in host:
        return "google-chrome"
    if "docker" in host:
        return "docker"
    if "nodesource" in host:
        return "nodesource"
    if host.endswith(".debian.org"):
        if "security" in host:
            return "debian-security"
        return "debian"
    if "ubuntu.com" in host and "ubuntu" in path:
        return "ubuntu"
    if host.endswith(".pkg.dev") and path.startswith("projects/"):
        parts = path.split("/")
        if len(parts) >= 2:
            return parts[1].rstrip("/")
    if ".s3." in host:
        bucket = host.split(".s3.")[0]
        if bucket.startswith("brave"):
            return "brave"
        return bucket
    if "codeiumdata" in host:
        return "windsurf"
    if "yandex" in host and "launchpad" in path:
        parts = path.split("/")
        idx = parts.index("launchpad") if "launchpad" in parts else -1
        if idx >= 0 and idx + 1 < len(parts):
            return "-".join(parts[idx + 1:])
    if host.endswith(".griffo.io"):
        return host.split(".")[-2]

    skip = {"apt", "repo", "repos", "packages", "stable", "dists", "ubuntu"}
    segments = [s for s in path.split("/") if s and s not in skip]
    if host.count(".") >= 2:
        base = host.rsplit(".", 2)[-2]
    else:
        base = host
    if segments:
        return f"{base}-{segments[0]}".strip("-")
    return base


_OFFICIAL_HOSTS = {
    "deb.debian.org",
    "security.debian.org",
    "archive.ubuntu.com",
    "security.ubuntu.com",
    "us.archive.ubuntu.com",
}

# Standard APT suite aliases — not tied to any specific distro
_ALIASES = {"stable", "testing", "unstable", "oldstable", "sid", "experimental", "devel"}


def _is_official_repo(url: str) -> bool:
    """Check if URL belongs to an official Debian/Ubuntu distribution repository."""
    host = urlparse(url).hostname or ""
    if host in _OFFICIAL_HOSTS:
        return True
    # ftp.us.debian.org, ftp.debian.org, etc.
    if host.startswith("ftp.") and host.endswith(".debian.org"):
        return True
    return False


def _fetch_dists(url: str) -> list[str]:
    """Fetch available distributions from a repository by listing its dists/ directory.

    Returns list of distribution names, or empty list on failure.
    """
    parsed = urlparse(url)
    if parsed.scheme not in ("http", "https"):
        return []

    base = url.rstrip("/") + "/dists/"
    try:
        req = urllib.request.Request(base, headers={"User-Agent": "apt-repository-list/1.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            if resp.status != 200:
                return []
            html = resp.read().decode("utf-8", errors="replace")
    except (urllib.error.URLError, OSError, TimeoutError):
        return []

    parser = _DirListParser()
    parser.feed(html)

    # filter out non-distribution entries (Release, InRelease, etc.)
    dists = []
    for name in parser.entries:
        if name in ("Release", "InRelease", "Release.gpg", "by-hash"):
            continue
        dists.append(name)
    return dists


def _parse_pins() -> list[dict]:
    """Parse pin rules from /etc/apt/preferences and preferences.d/."""
    paths = ["/etc/apt/preferences"]
    pref_dir = Path("/etc/apt/preferences.d")
    if pref_dir.is_dir():
        paths += [str(p) for p in pref_dir.iterdir() if p.is_file()]

    pins: list[dict] = []
    for path in paths:
        try:
            content = Path(path).read_text()
        except OSError:
            continue

        for block in re.split(r"\n\n+", content):
            pkg = pin = None
            priority = None
            for line in block.splitlines():
                line = line.strip()
                if line.startswith("#") or not line:
                    continue
                if line.lower().startswith("package:"):
                    pkg = line.split(":", 1)[1].strip()
                elif line.lower().startswith("pin:"):
                    pin = line.split(":", 1)[1].strip()
                elif line.lower().startswith("pin-priority:"):
                    try:
                        priority = int(line.split(":", 1)[1].strip())
                    except ValueError:
                        pass
            if pin and priority is not None:
                pins.append({"package": pkg, "pin": pin, "priority": priority})

    return pins


def _match_pin(uri: str, pins: list[dict]) -> tuple[bool, int | None]:
    """Check if any pin rule matches the given URI by origin hostname."""
    parsed = urlparse(uri)
    host = parsed.hostname
    if not host:
        return False, None

    for p in pins:
        pin_str = p["pin"]
        m = re.match(r"origin\s+(.+)", pin_str, re.IGNORECASE)
        if m and m.group(1).strip().lower() == host.lower():
            return True, p["priority"]

    return False, None


def summary() -> list[dict]:
    """List all APT repositories with all available branches.

    For each configured repository URL, fetches the dists/ directory to discover
    all available branches (not just the configured ones). Shows configured state
    and pin information for each branch.

    Returns:
        List of dicts with name, url, branch, configured, pinned, pin-priority.
    """
    sl = aptsources.sourceslist.SourcesList(deb822=True)
    pins = _parse_pins()

    # collect configured (url, branch) pairs and unique urls
    configured: set[tuple[str, str]] = set()
    urls: set[str] = set()

    for entry in sl.exploded_list():
        if not entry.type:
            continue
        # skip non-network sources (cdrom, etc.)
        if not entry.uri or not entry.uri.startswith(("http://", "https://")):
            continue
        # only show official distribution repos
        if not _is_official_repo(entry.uri):
            continue
        urls.add(entry.uri)
        configured.add((entry.uri, entry.dist))

    repos: list[dict] = []
    seen: set[tuple[str, str]] = set()

    for url in sorted(urls):
        name = _derive_name(url)
        pinned, pin_priority = _match_pin(url, pins)

        # discover all branches from dists/ for official repos
        # filter to current codename + suffixes + standard suite aliases
        codename = distro.codename()
        available = _fetch_dists(url) if _is_official_repo(url) else []
        available = [
            b for b in available
            if b == codename
            or b.startswith(f"{codename}-")
            or b in _ALIASES
        ]

        if available:
            for branch in sorted(available):
                key = (url, branch)
                if key in seen:
                    continue
                seen.add(key)
                repos.append({
                    "name": name,
                    "url": url,
                    "branch": branch,
                    "configured": key in configured,
                    "pinned": pinned,
                    "pin-priority": pin_priority,
                })
        else:
            # fallback: show only configured branches for this url
            for entry in sl.exploded_list():
                if not entry.type or entry.uri != url:
                    continue
                key = (url, entry.dist)
                if key in seen:
                    continue
                seen.add(key)
                repos.append({
                    "name": name,
                    "url": url,
                    "branch": entry.dist,
                    "configured": True,
                    "pinned": pinned,
                    "pin-priority": pin_priority,
                })

    return repos


def main():
    cli = CLI(version="1.1.0", prog=__file__, description="List APT repositories")

    @cli.command(default=True)
    def summary_cmd() -> list[dict]:
        """Show all APT repositories with all available branches"""
        return summary()

    cli.run()


if __name__ == "__main__":
    main()
