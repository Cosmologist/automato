#!/usr/bin/env python3
"""Schedules Sync — update employee schedules from various data sources."""

from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

import openpyxl


SCRIPT_DIR = Path(__file__).resolve().parent
SCHEDULES_FILE = SCRIPT_DIR / "schedules.xlsm"
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
NC = "\033[0m"


# ── Summary ──────────────────────────────────────────────────
def print_summary() -> None:
    print(
        f"""--- Schedules Sync ---
Updates employee schedules in schedules.xlsm based on various data sources.

Usage:
  {Path(sys.argv[0]).name} current     — List all employee names from schedules.xlsm
  {Path(sys.argv[0]).name} check       — Preview pending changes
  {Path(sys.argv[0]).name}             — Interactive mode

Examples:
  {Path(sys.argv[0]).name} current
  {Path(sys.argv[0]).name}
""",
        file=sys.stderr,
    )


# ── Pre-flight checks ────────────────────────────────────────
def preflight() -> None:
    if not SCHEDULES_FILE.exists():
        print(f"Error: schedule file not found: {SCHEDULES_FILE}", file=sys.stderr)
        sys.exit(1)


# ── FIO helpers ──────────────────────────────────────────────
def normalize_fio(name: str) -> str:
    name = name.replace("\xa0", " ")
    name = re.sub(r"\s+", " ", name)
    return name.strip().replace("ё", "е").replace("Ё", "Е")


# ── XLSM parser ──────────────────────────────────────────────
def parse_schedules(filepath: Path) -> dict:
    """
    Parse schedules.xlsm and return employee data.

    Returns
    -------
    dict with keys:
      tables: list of dicts, one per table:
        - header_rows: int (2 for table 1, 1 for table 2)
        - employees: list of dicts with keys "row_num", "fio_raw", "fio"
    """
    wb = openpyxl.load_workbook(filepath, data_only=True, keep_vba=False)
    ws = wb.active
    rows = list(ws.iter_rows(min_row=1, max_row=ws.max_row, max_col=ws.max_column))

    # Find empty rows (all cells None)
    empty_indices = [
        i for i, row in enumerate(rows)
        if all(c.value is None for c in row)
    ]
    if not empty_indices:
        print("Error: cannot find table separator (empty row)", file=sys.stderr)
        sys.exit(1)

    sep_idx = empty_indices[0]  # 0-based row index of empty separator

    # Table 1: header = rows 0,1 (2 rows), data = rows 2..sep_idx-1
    # Table 2: header = row sep_idx+1 (1 row), data = rows sep_idx+2..
    tables = []

    # Table 1
    t1_employees = []
    for r in rows[2:sep_idx]:
        num_cell = r[0].value
        fio_raw = str(r[1].value or "")
        if num_cell is None:
            continue
        t1_employees.append({
            "row_num": r[0].row,
            "fio_raw": fio_raw,
            "fio": normalize_fio(fio_raw),
        })
    tables.append({"header_rows": 2, "employees": t1_employees})

    # Table 2
    t2_employees = []
    for r in rows[sep_idx + 2:]:
        num_cell = r[0].value
        fio_raw = str(r[1].value or "")
        if num_cell is None:
            continue
        t2_employees.append({
            "row_num": r[0].row,
            "fio_raw": fio_raw,
            "fio": normalize_fio(fio_raw),
        })
    tables.append({"header_rows": 1, "employees": t2_employees})

    wb.close()
    return {"tables": tables, "filepath": str(filepath)}


# ── Interactive prompt ──────────────────────────────────────
def interactive_prompt() -> argparse.Namespace:
    print("Select action:", file=sys.stderr)
    print("  1) Current — list all employee names", file=sys.stderr)
    print("  2) Check — preview changes without applying", file=sys.stderr)
    print("  3) Sync — read source data and update schedules", file=sys.stderr)
    choice = input("Enter number [1-3]: ").strip()

    args = argparse.Namespace()
    match choice:
        case "1":
            args.mode = "current"
        case "2":
            args.mode = "check"
        case "3":
            args.mode = "sync"
        case _:
            print(f"Invalid choice: {choice}", file=sys.stderr)
            sys.exit(1)
    return args


# ── Modes ────────────────────────────────────────────────────
def cmd_current() -> None:
    data = parse_schedules(SCHEDULES_FILE)
    for ti, tbl in enumerate(data["tables"], start=1):
        print(f"Table {ti}:", file=sys.stderr)
        for emp in tbl["employees"]:
            print(emp["fio"])


def cmd_check() -> None:
    data = parse_schedules(SCHEDULES_FILE)
    for ti, tbl in enumerate(data["tables"], start=1):
        print(f"\nTable {ti} ({len(tbl['employees'])} employees, header_rows={tbl['header_rows']}):", file=sys.stderr)
        for emp in tbl["employees"]:
            print(f"  Row {emp['row_num']}: {emp['fio']}", file=sys.stderr)


def cmd_sync() -> None:
    print("Sync mode — updating schedules...", file=sys.stderr)


# ── Main ─────────────────────────────────────────────────────
def main() -> None:
    print_summary()

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--check", action="store_true")
    parser.add_argument("mode", nargs="?", default="")

    args = parser.parse_args()

    if not args.mode:
        ns = interactive_prompt()
    else:
        ns = args

    preflight()

    if ns.mode in ("current", "cur"):
        cmd_current()
    elif ns.mode in ("check", "c"):
        cmd_check()
    elif ns.mode in ("sync", "s"):
        cmd_sync()
    else:
        print(f"Unknown mode: {ns.mode}", file=sys.stderr)
        print("  Valid modes: current, check, sync", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
