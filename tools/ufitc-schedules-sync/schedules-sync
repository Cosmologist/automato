#!/usr/bin/env python3
"""Schedules Sync — update employee schedules from various data sources."""

from __future__ import annotations

import argparse
import re
import sys
from copy import copy
from dataclasses import dataclass
from pathlib import Path
from typing import Any

import openpyxl
from docx import Document
from openpyxl.styles import Font, PatternFill, Border, Alignment
from openpyxl.utils import get_column_letter


SCRIPT_DIR = Path(__file__).resolve().parent
SCHEDULES_FILE = SCRIPT_DIR / "schedules.xlsm"
EMPLOYEES_FILE = SCRIPT_DIR / "employees.docx"
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
NC = "\033[0m"


# ── Summary ──────────────────────────────────────────────────
def print_summary() -> None:
    print(
        f"""--- Schedules Sync ---
Updates employee schedules in schedules.xlsm based on various data sources.

Usage:
  {Path(sys.argv[0]).name} current     — List all employee names from schedules.xlsm
  {Path(sys.argv[0]).name} employees   — List all employee names + labels from employees.docx
  {Path(sys.argv[0]).name} diff        — Compare schedules vs employees (full outer join)
  {Path(sys.argv[0]).name} clean       — Remove from schedules rows without pair in employees
  {Path(sys.argv[0]).name}             — Interactive mode

Examples:
  {Path(sys.argv[0]).name} current
  {Path(sys.argv[0]).name} employees
  {Path(sys.argv[0]).name} diff
  {Path(sys.argv[0]).name} clean
  {Path(sys.argv[0]).name}
""",
        file=sys.stderr,
    )


# ── Pre-flight checks ────────────────────────────────────────
def preflight(mode: str = "") -> None:
    if not SCHEDULES_FILE.exists():
        print(f"Error: file not found: {SCHEDULES_FILE}", file=sys.stderr)
        sys.exit(1)
    if mode in ("employees", "emp", "diff", "clean") and not EMPLOYEES_FILE.exists():
        print(f"Error: file not found: {EMPLOYEES_FILE}", file=sys.stderr)
        sys.exit(1)


# ── FIO helpers ──────────────────────────────────────────────
def normalize_fio(name: str) -> str:
    name = name.replace("\xa0", " ")
    name = re.sub(r"\s+", " ", name)
    return name.strip().replace("ё", "е").replace("Ё", "Е")


# ── XLSM parser ──────────────────────────────────────────────
def parse_schedules(filepath: Path) -> dict:
    """
    Parse schedules.xlsm and return employee data.

    Returns
    -------
    dict with keys:
      tables: list of dicts, one per table:
        - header_rows: int (2 for table 1, 1 for table 2)
        - employees: list of dicts with keys "row_num", "fio_raw", "fio"
    """
    wb = openpyxl.load_workbook(filepath, data_only=True, keep_vba=False)
    ws = wb.active
    rows = list(ws.iter_rows(min_row=1, max_row=ws.max_row, max_col=ws.max_column))

    # Find empty rows (all cells None)
    empty_indices = [
        i for i, row in enumerate(rows)
        if all(c.value is None for c in row)
    ]
    if not empty_indices:
        print("Error: cannot find table separator (empty row)", file=sys.stderr)
        sys.exit(1)

    sep_idx = empty_indices[0]  # 0-based row index of empty separator

    # Table 1: header = rows 0,1 (2 rows), data = rows 2..sep_idx-1
    # Table 2: header = row sep_idx+1 (1 row), data = rows sep_idx+2..
    tables = []

    # Table 1
    t1_employees = []
    for r in rows[2:sep_idx]:
        num_cell = r[0].value
        fio_raw = str(r[1].value or "")
        if num_cell is None:
            continue
        t1_employees.append({
            "row_num": r[0].row,
            "fio_raw": fio_raw,
            "fio": normalize_fio(fio_raw),
        })
    tables.append({"header_rows": 2, "employees": t1_employees})

    # Table 2
    t2_employees = []
    for r in rows[sep_idx + 2:]:
        num_cell = r[0].value
        fio_raw = str(r[1].value or "")
        if num_cell is None:
            continue
        t2_employees.append({
            "row_num": r[0].row,
            "fio_raw": fio_raw,
            "fio": normalize_fio(fio_raw),
        })
    tables.append({"header_rows": 1, "employees": t2_employees})

    wb.close()
    return {"tables": tables, "filepath": str(filepath)}


def get_all_employees() -> list[dict]:
    """Return flat list of all employees from both tables, sorted by fio."""
    data = parse_schedules(SCHEDULES_FILE)
    result = []
    for ti, tbl in enumerate(data["tables"]):
        for emp in tbl["employees"]:
            result.append({**emp, "table_index": ti})
    result.sort(key=lambda e: e["fio"])
    return result


# ── DOCX parser ──────────────────────────────────────────────
def parse_employees(filepath: Path) -> list[dict]:
    """Parse employees.docx and return sorted list of {fio, label}."""
    doc = Document(str(filepath))
    table = doc.tables[0]
    result = []
    for row in table.rows[1:]:  # skip header
        cells = [c.text.strip() for c in row.cells]
        fio_raw = cells[1]
        label_raw = cells[2] if len(cells) > 2 else ""
        fio = normalize_fio(fio_raw).rstrip(",").strip()
        if not fio:
            continue
        result.append({
            "fio_raw": fio_raw,
            "fio": fio,
            "label": label_raw,
        })
    result.sort(key=lambda e: e["fio"])
    return result


# ── Sheet mapping (для удаления строк) ─────────────────────
@dataclass
class CellData:
    value: Any
    font: Font
    fill: PatternFill
    border: Border
    alignment: Alignment
    number_format: str


class SheetMapping:
    """Снимок листа: значения, стили, объединения, размеры."""

    def __init__(self, ws: openpyxl.worksheet.worksheet.Worksheet):
        self.cells: dict[tuple[int, int], CellData] = {}
        self.merged: list[tuple[int, int, int, int]] = []
        self.row_heights: dict[int, float] = {}
        self.col_widths: dict[int, float] = {}
        self.max_row = ws.max_row or 0
        self.max_col = ws.max_column or 0
        self._scan(ws)

    def _scan(self, ws):
        for mr in ws.merged_cells.ranges:
            self.merged.append((mr.min_row, mr.min_col, mr.max_row, mr.max_col))
        for r in range(1, self.max_row + 1):
            h = ws.row_dimensions[r].height
            if h:
                self.row_heights[r] = h
        for c in range(1, self.max_col + 1):
            w = ws.column_dimensions[get_column_letter(c)].width
            if w:
                self.col_widths[c] = w
        for row in ws.iter_rows(min_row=1, max_row=self.max_row, max_col=self.max_col):
            for cell in row:
                if cell.value is not None:
                    self.cells[(cell.row, cell.column)] = CellData(
                        value=copy(cell.value),
                        font=copy(cell.font),
                        fill=copy(cell.fill),
                        border=copy(cell.border),
                        alignment=copy(cell.alignment),
                        number_format=cell.number_format,
                    )

    def remove_row(self, row_num: int):
        keys = [(r, c) for (r, c) in self.cells if r == row_num]
        for k in keys:
            del self.cells[k]

        new_cells = {}
        for (r, c), data in self.cells.items():
            new_cells[(r - 1 if r > row_num else r, c)] = data
        self.cells = new_cells

        new_merged = []
        for r1, c1, r2, c2 in self.merged:
            if r1 > row_num and r2 > row_num:
                new_merged.append((r1 - 1, c1, r2 - 1, c2))
            elif r1 <= row_num <= r2:
                new_merged.append((r1, c1, r2 - 1, c2))
            else:
                new_merged.append((r1, c1, r2, c2))
        self.merged = new_merged

        new_heights = {}
        for r, h in self.row_heights.items():
            if r < row_num:
                new_heights[r] = h
            elif r > row_num:
                new_heights[r - 1] = h
        self.row_heights = new_heights
        self.max_row -= 1

    def render(self, ws: openpyxl.worksheet.worksheet.Worksheet):
        for mr in list(ws.merged_cells.ranges):
            ws.unmerge_cells(str(mr))
        if ws.max_row and ws.max_column:
            ws.delete_rows(1, ws.max_row)

        for (r, c), data in self.cells.items():
            cell = ws.cell(row=r, column=c)
            cell.value = data.value
            cell.font = copy(data.font)
            cell.fill = copy(data.fill)
            cell.border = copy(data.border)
            cell.alignment = copy(data.alignment)
            cell.number_format = data.number_format

        for r1, c1, r2, c2 in self.merged:
            ws.merge_cells(start_row=r1, start_column=c1, end_row=r2, end_column=c2)
        for r, h in self.row_heights.items():
            ws.row_dimensions[r].height = h
        for c, w in self.col_widths.items():
            ws.column_dimensions[get_column_letter(c)].width = w


# ── Interactive prompt ──────────────────────────────────────
def interactive_prompt() -> argparse.Namespace:
    print("Select action:", file=sys.stderr)
    print("  1) Current   — list names from schedules.xlsm", file=sys.stderr)
    print("  2) Employees — list names + labels from employees.docx", file=sys.stderr)
    print("  3) Diff      — compare schedules vs employees", file=sys.stderr)
    print("  4) Clean     — remove rows without pair in employees", file=sys.stderr)
    print("  5) Check     — preview pending changes", file=sys.stderr)
    print("  6) Sync      — update schedules", file=sys.stderr)
    choice = input("Enter number [1-6]: ").strip()

    args = argparse.Namespace()
    match choice:
        case "1":
            args.mode = "current"
        case "2":
            args.mode = "employees"
        case "3":
            args.mode = "diff"
        case "4":
            args.mode = "clean"
        case "5":
            args.mode = "check"
        case "6":
            args.mode = "sync"
        case _:
            print(f"Invalid choice: {choice}", file=sys.stderr)
            sys.exit(1)
    return args


# ── Modes ────────────────────────────────────────────────────
def cmd_current() -> None:
    sorted_employees = get_all_employees()
    for emp in sorted_employees:
        print(emp["fio"])


def cmd_employees() -> None:
    data = parse_employees(EMPLOYEES_FILE)
    for emp in data:
        label_part = f"  [{emp['label']}]" if emp["label"] else ""
        print(f"{emp['fio']}{label_part}")


def cmd_diff() -> None:
    sched = get_all_employees()
    emp = parse_employees(EMPLOYEES_FILE)
    emp_by_fio = {e["fio"]: e for e in emp}

    rows: list[tuple[str, str, str, str]] = []  # (sched_fio, emp_fio, label, color)

    i = j = 0
    while i < len(sched) and j < len(emp):
        cmp = (sched[i]["fio"] > emp[j]["fio"]) - (sched[i]["fio"] < emp[j]["fio"])
        if cmp == 0:
            label = emp_by_fio[sched[i]["fio"]].get("label", "")
            rows.append((sched[i]["fio"], emp[j]["fio"], label, ""))
            i += 1
            j += 1
        elif cmp < 0:
            rows.append((sched[i]["fio"], "", "", RED))
            i += 1
        else:
            label = emp[j].get("label", "")
            rows.append(("", emp[j]["fio"], label, GREEN))
            j += 1

    for e in sched[i:]:
        rows.append((e["fio"], "", "", RED))
    for e in emp[j:]:
        rows.append(("", e["fio"], e.get("label", ""), GREEN))

    n_width = len(str(len(rows)))
    w1 = max((len(r[0]) for r in rows), default=0)
    w2 = max((len(r[1]) for r in rows), default=0)
    w1 = max(w1, len("schedule"))
    w2 = max(w2, len("employees"))
    sep = "  "

    hdr = f"{'#'.ljust(n_width)}{sep}{'schedule'.ljust(w1)}{sep}{'employees'.ljust(w2)}{sep}label"
    print(hdr)
    print("-" * len(hdr))

    for idx, (s_fio, e_fio, label, color) in enumerate(rows, start=1):
        line = f"{str(idx).ljust(n_width)}{sep}{s_fio.ljust(w1)}{sep}{e_fio.ljust(w2)}{sep}{label}"
        if color:
            print(f"{color}{line}{NC}")
        else:
            print(line)


def cmd_check() -> None:
    data = parse_schedules(SCHEDULES_FILE)
    for ti, tbl in enumerate(data["tables"], start=1):
        print(f"\nTable {ti} ({len(tbl['employees'])} employees, header_rows={tbl['header_rows']}):", file=sys.stderr)
        for emp in tbl["employees"]:
            print(f"  Row {emp['row_num']}: {emp['fio']}", file=sys.stderr)


def cmd_sync() -> None:
    print("Sync mode — updating schedules...", file=sys.stderr)


def cmd_clean() -> None:
    docx_employees = parse_employees(EMPLOYEES_FILE)
    docx_fios = {e["fio"] for e in docx_employees}

    sched_employees = get_all_employees()
    to_remove = [e for e in sched_employees if e["fio"] not in docx_fios]
    to_remove.sort(key=lambda e: e["row_num"], reverse=True)

    if not to_remove:
        print("Nothing to remove — all schedule rows have a pair in employees.", file=sys.stderr)
        return

    print(f"Removing {len(to_remove)} rows...", file=sys.stderr)
    wb = openpyxl.load_workbook(SCHEDULES_FILE, keep_vba=True)
    ws = wb.active
    sm = SheetMapping(ws)

    for emp in to_remove:
        print(f"{RED}-{NC} Row {emp['row_num']}: {emp['fio']}", file=sys.stderr)
        sm.remove_row(emp["row_num"])

    sheet_name = "Clean"
    if sheet_name in wb.sheetnames:
        del wb[sheet_name]
    ws_new = wb.create_sheet(sheet_name)
    sm.render(ws_new)

    wb.save(SCHEDULES_FILE)
    wb.close()
    print(f"Done. Cleaned data written to new sheet '{sheet_name}'.", file=sys.stderr)


# ── Main ─────────────────────────────────────────────────────
def main() -> None:
    print_summary()

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--check", action="store_true")
    parser.add_argument("mode", nargs="?", default="")

    args = parser.parse_args()

    if not args.mode:
        ns = interactive_prompt()
    else:
        ns = args

    preflight(ns.mode)

    if ns.mode in ("current", "cur"):
        cmd_current()
    elif ns.mode in ("employees", "emp"):
        cmd_employees()
    elif ns.mode in ("diff"):
        cmd_diff()
    elif ns.mode in ("clean"):
        cmd_clean()
    elif ns.mode in ("check", "c"):
        cmd_check()
    elif ns.mode in ("sync", "s"):
        cmd_sync()
    else:
        print(f"Unknown mode: {ns.mode}", file=sys.stderr)
        print("  Valid modes: current, employees, diff, clean, check, sync", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
