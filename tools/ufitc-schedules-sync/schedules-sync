def cmd_sync() -> None:
    print("Sync mode — updating schedules...", file=sys.stderr)


def _renumber_column_a(ws) -> None:
    """Renumber column A for each table (1-based, per table)."""
    empty_row = None
    for r in range(1, ws.max_row + 1):
        if all(ws.cell(row=r, column=c).value is None for c in range(1, ws.max_column + 1)):
            empty_row = r
            break
    if empty_row is None:
        return

    num = 1
    for r in range(3, empty_row):
        if ws.cell(row=r, column=1).value is not None:
            ws.cell(row=r, column=1).value = num
            num += 1

    num = 1
    for r in range(empty_row + 2, ws.max_row + 1):
        if ws.cell(row=r, column=1).value is not None:
            ws.cell(row=r, column=1).value = num
            num += 1


def cmd_clean() -> None:
    docx_employees = parse_employees(EMPLOYEES_FILE)
    docx_fios = {e["fio"] for e in docx_employees}

    sched_employees = get_all_employees()
    to_remove = [e for e in sched_employees if e["fio"] not in docx_fios]
    to_remove.sort(key=lambda e: e["row_num"], reverse=True)

    if not to_remove:
        print("Nothing to remove — all schedule rows have a pair in employees.", file=sys.stderr)
        return

    print(f"Removing {len(to_remove)} rows...", file=sys.stderr)
    wb = openpyxl.load_workbook(SCHEDULES_FILE, keep_vba=True)
    ws = wb.active
    sm = SheetMapping(ws)

    for emp in to_remove:
        print(f"{RED}-{NC} Row {emp['row_num']}: {emp['fio']}", file=sys.stderr)
        sm.remove_row(emp["row_num"])

    sheet_name = "Clean"
    if sheet_name in wb.sheetnames:
        del wb[sheet_name]
    ws_new = wb.create_sheet(sheet_name)
    sm.render(ws_new)
    print("Renumbering column A...", file=sys.stderr)
    _renumber_column_a(ws_new)

    wb.save(SCHEDULES_FILE)
    wb.close()
    print(f"Done. Cleaned data written to new sheet '{sheet_name}'.", file=sys.stderr)


# ── Collect (departs → schedule sheet) ──────────────────────
DAY_NAMES = ["пн", "вт", "ср", "чт", "пт", "сб", "вс"]


def _spiral_scan(ws) -> tuple[int, int] | None:
    """Find first ФИО cell via clockwise spiral from A1. Returns (col, row)."""
    max_row = ws.max_row or 0
    max_col = ws.max_column or 0
    limit = max(max_row, max_col)

    for N in range(1, limit + 1):
        if N <= max_col:
            for r in range(1, N + 1):
                if r <= max_row:
                    val = ws.cell(row=r, column=N).value
                    if is_fio_cell(val):
                        return (N, r)
        if N <= max_row:
            for c in range(N - 1, 0, -1):
                if c <= max_col:
                    val = ws.cell(row=N, column=c).value
                    if is_fio_cell(val):
                        return (c, N)
    return None


def collect_from_file(filepath: Path, working_days: int) -> list[dict] | None:
    """Scan one depart file and return list of {fio, data} or None if no ФИО found."""
    wb = openpyxl.load_workbook(filepath, data_only=True)
    ws = wb.active
    if ws.max_row is None or ws.max_column is None:
        wb.close()
        return None

    pos = _spiral_scan(ws)
    if pos is None:
        wb.close()
        return None

    fio_col, start_row = pos
    max_row = ws.max_row
    max_col = ws.max_column
    data_end = min(fio_col + working_days, max_col)

    employees = []
    for r in range(start_row, max_row + 1):
        cell_val = ws.cell(row=r, column=fio_col).value
        if cell_val is None:
            break
        cleaned = clean_fio_cell(cell_val)
        if not cleaned or cleaned.count(" ") != 2:
            continue

        data = []
        for c in range(fio_col + 1, data_end + 1):
            data.append(ws.cell(row=r, column=c).value)

        if not any(v is not None for v in data):
            continue
        employees.append({"fio": cleaned, "data": data})

    wb.close()
    return employees


def render_schedule_sheet(employees: list[dict], working_days: int) -> None:
    """Render collected employees into a new 'schedule' sheet in schedules.xlsx."""
    wb = openpyxl.load_workbook(SCHEDULES_FILE, keep_vba=True)

    if "schedule" in wb.sheetnames:
        del wb["schedule"]
    ws = wb.create_sheet("schedule")

    for idx, emp in enumerate(employees, start=1):
        ws.cell(row=idx, column=1, value=idx)
        ws.cell(row=idx, column=2, value=emp["fio"])
        for di, val in enumerate(emp["data"]):
            if val is not None:
                ws.cell(row=idx, column=3 + di, value=val)

    wb.save(SCHEDULES_FILE)
    wb.close()


def cmd_collect(working_days: int) -> None:
    """Collect employee data from all departs/*.xlsx into a new schedule sheet."""
    if not DEPARTS_DIR.is_dir():
        print(f"Error: directory not found: {DEPARTS_DIR}", file=sys.stderr)
        sys.exit(1)

    files = sorted(DEPARTS_DIR.glob("*.xlsx"))
    files = [f for f in files if not f.name.startswith(".~lock.")]

    if not files:
        print(f"Error: no .xlsx files in {DEPARTS_DIR}", file=sys.stderr)
        sys.exit(1)

    all_employees: list[dict] = []

    for filepath in files:
        employees = collect_from_file(filepath, working_days)
        if employees is None:
            print(f"{YELLOW}skip{NC} {filepath.name} — no ФИО found", file=sys.stderr)
            continue
        print(
            f"{GREEN}→{NC} departs/{filepath.name}: "
            f"{len(employees)} сотрудников",
            file=sys.stderr,
        )
        for emp in employees:
            print(f"  {emp['fio']}", file=sys.stderr)
        all_employees.extend(employees)

    if not all_employees:
        print("No employees found in any file.", file=sys.stderr)
        return

    print(f"\nRendering {len(all_employees)} employees to schedule sheet...", file=sys.stderr)
    render_schedule_sheet(all_employees, working_days)
    for idx, emp in enumerate(all_employees, start=1):
        print(f"{GREEN}+{NC} schedule A{idx}: {emp['fio']}", file=sys.stderr)
    print(f"Done. Created sheet 'schedule' in {SCHEDULES_FILE.name}.", file=sys.stderr)


# ── Merge (Clean + schedule + first sheet) ────────────────────
def _find_sep_idx(ws) -> int | None:
    for i, row in enumerate(ws.iter_rows(min_row=1, max_row=ws.max_row, max_col=ws.max_column)):
        if all(c.value is None for c in row):
            return i
    return None


def _parse_schedule_sheet(ws) -> list[dict]:
    employees = []
    for r in range(1, (ws.max_row or 0) + 1):
        fio_raw = str(ws.cell(row=r, column=2).value or "")
        fio = normalize_fio(fio_raw)
        if not fio:
            continue
        data = []
        for c in range(3, (ws.max_column or 0) + 1):
            data.append(ws.cell(row=r, column=c).value)
        employees.append({"fio": fio, "data": data})
    return employees


def _parse_t1_employees(ws, sep_idx, mapping) -> list[dict]:
    employees = []
    for r in range(2, sep_idx):
        row_num = r + 1
        num_val = ws.cell(row=row_num, column=1).value
        fio_raw = str(ws.cell(row=row_num, column=2).value or "")
        if num_val is None:
            continue
        fio = normalize_fio(fio_raw)
        if fio:
            employees.append({"row_num": row_num, "fio": fio})
    return employees


def cmd_merge() -> None:
    wb = openpyxl.load_workbook(SCHEDULES_FILE, keep_vba=True)

    if "Clean" not in wb.sheetnames:
        print(f"{RED}Error:{NC} sheet 'Clean' not found — run 'clean' first", file=sys.stderr)
        wb.close()
        sys.exit(1)
    if "schedule" not in wb.sheetnames:
        print(f"{RED}Error:{NC} sheet 'schedule' not found — run 'collect' first", file=sys.stderr)
        wb.close()
        sys.exit(1)

    ws_first = wb.worksheets[0]
    ws_clean = wb["Clean"]
    ws_schedule = wb["schedule"]

    clean_map = SheetMapping(ws_clean)
    first_map = SheetMapping(ws_first)

    sep_idx = _find_sep_idx(ws_clean)
    first_sep = _find_sep_idx(ws_first)
    if sep_idx is None or first_sep is None:
        print(f"{RED}Error:{NC} cannot find table separator in Clean or first sheet", file=sys.stderr)
        wb.close()
        sys.exit(1)

    t1_start = 3
    t1_end = sep_idx
    t2_clean_start = sep_idx + 2
    t2_first_start = first_sep + 2

    t1_employees = _parse_t1_employees(ws_clean, sep_idx, clean_map)
    schedule_employees = _parse_schedule_sheet(ws_schedule)

    if not schedule_employees:
        print(f"{YELLOW}skip{NC} schedule sheet is empty — nothing to merge", file=sys.stderr)
        wb.close()
        return
    if not t1_employees:
        print(f"{YELLOW}skip{NC} Clean table 1 is empty — nothing to merge into", file=sys.stderr)
        wb.close()
        return

    t1_by_fio = {e["fio"]: e for e in t1_employees}
    sched_by_fio = {e["fio"]: e for e in schedule_employees}

    matched = set()

    for se in schedule_employees:
        if se["fio"] in t1_by_fio:
            matched.add(se["fio"])
            t1_row = t1_by_fio[se["fio"]]["row_num"]
            for di, val in enumerate(se["data"]):
                clean_map.set_cell_value(t1_row, 3 + di, val)
            print(f"{GREEN}→{NC} {se['fio']} — updated from schedule", file=sys.stderr)
        else:
            pass

    orphans = [e for e in t1_employees if e["fio"] not in matched]

    inserts = [se for se in schedule_employees if se["fio"] not in matched]
    if inserts:
        existing_sorted = sorted(t1_employees, key=lambda e: e["fio"])
        insert_plan = []
        for ins in inserts:
            fio = ins["fio"]
            pos = 0
            for idx, ee in enumerate(existing_sorted):
                if fio < ee["fio"]:
                    pos = idx
                    break
            else:
                pos = len(existing_sorted)
            if pos == 0:
                after_row = t1_start - 1
            else:
                after_row = existing_sorted[pos - 1]["row_num"]
            insert_plan.append((ins, after_row))
            existing_sorted.insert(pos, ins)

        all_after_rows = [ar for _, ar in insert_plan]
        final_positions = clean_map.bulk_insert_rows(all_after_rows)

        red_fill = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")

        for ins, after_row in insert_plan:
            new_row = final_positions[after_row]

            for src_row in range(new_row - 1, 0, -1):
                if clean_map.get_row(src_row):
                    clean_map.clone_row_style(src_row, new_row)
                    break
            else:
                if t1_employees:
                    clean_map.clone_row_style(t1_employees[0]["row_num"], new_row)

            clean_map.set_cell_value(new_row, 1, 0)
            clean_map.set_cell_value(new_row, 2, ins["fio"])
            for di, val in enumerate(ins["data"]):
                if val is not None:
                    clean_map.set_cell_value(new_row, 3 + di, val)
            clean_map.set_cell_fill(new_row, 1, red_fill)
            clean_map.set_cell_fill(new_row, 2, red_fill)

            print(f"{GREEN}+{NC} {ins['fio']} — new (red) at row {new_row}", file=sys.stderr)

    for emp in t1_employees:
        shift = sum(1 for ar in all_after_rows if ar < emp["row_num"])
        emp["row_num"] += shift

    orange_fill = PatternFill(start_color="FFA500", end_color="FFA500", fill_type="solid")
    for emp in orphans:
        for col in range(1, clean_map.max_col + 1):
            clean_map.set_cell_fill(emp["row_num"], col, orange_fill)
        print(f"{YELLOW}~{NC} {emp['fio']} — orphan (orange)", file=sys.stderr)

    new_sep = (sep_idx + 1) + len(inserts)
    t2_src_rows = list(range(new_sep + 1, clean_map.max_row + 1))
    for r in reversed(t2_src_rows):
        clean_map.remove_row(r)

    t2_target_start = clean_map.max_row + 2
    first_max_col = first_map.max_col
    for src_row in range(t2_first_start, first_map.max_row + 1):
        dst_row = t2_target_start + (src_row - t2_first_start)
        if dst_row > clean_map.max_row:
            clean_map.max_row = dst_row
        for src_key, src_data in first_map.cells.items():
            if src_key[0] == src_row:
                clean_map.cells[(dst_row, src_key[1])] = CellData(
                    value=copy(src_data.value),
                    font=copy(src_data.font),
                    fill=copy(src_data.fill),
                    border=copy(src_data.border),
                    alignment=copy(src_data.alignment),
                    number_format=src_data.number_format,
                )
        clean_map.max_col = max(clean_map.max_col, first_max_col)

    for r1, c1, r2, c2 in first_map.merged:
        if r1 >= t2_first_start:
            offset = t2_target_start - t2_first_start
            clean_map.merged.append((r1 + offset, c1, r2 + offset, c2))

    if "Final" in wb.sheetnames:
        del wb["Final"]
    ws_final = wb.create_sheet("Final")
    clean_map.render(ws_final)
    _renumber_column_a(ws_final)
    wb.save(SCHEDULES_FILE)
    wb.close()
    print(f"Done. Merged data written to sheet 'Final'.", file=sys.stderr)


# ── Main ─────────────────────────────────────────────────────
def main() -> None:
    print_summary()

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--check", action="store_true")
    parser.add_argument("args", nargs="*", default=[])

    parsed = parser.parse_args()

    if not parsed.args:
        ns = interactive_prompt()
    else:
        ns = argparse.Namespace()
        ns.mode = parsed.args[0]
        ns.extra = parsed.args[1:]

    preflight(ns.mode)

    if ns.mode in ("current", "cur"):
        cmd_current()
    elif ns.mode in ("employees", "emp"):
        cmd_employees()
    elif ns.mode in ("diff"):
        cmd_diff()
    elif ns.mode in ("clean"):
        cmd_clean()
    elif ns.mode in ("check", "c"):
        cmd_check()
    elif ns.mode in ("sync", "s"):
        cmd_sync()
    elif ns.mode in ("collect", "col"):
        if hasattr(ns, "working_days"):
            wd = ns.working_days
        else:
            try:
                wd = int(ns.extra[0])
            except (IndexError, ValueError):
                print("Error: collect requires working days argument (e.g. collect 30)", file=sys.stderr)
                sys.exit(1)
        cmd_collect(wd)
    elif ns.mode in ("merge", "mrg"):
        cmd_merge()
    else:
        print(f"Unknown mode: {ns.mode}", file=sys.stderr)
        print("  Valid modes: current, employees, diff, clean, check, collect, sync, merge", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
