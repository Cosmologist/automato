def step_pretty() -> None:
    wb = openpyxl.load_workbook(SCHEDULES_FILE, keep_vba=True)
    if "Final" in wb.sheetnames:
        wb["Final"].title = "Лист 2"
    keep = "Лист 2" if "Лист 2" in wb.sheetnames else wb.sheetnames[0]
    for sn in list(wb.sheetnames):
        if sn != keep:
            del wb[sn]
    ws = wb.active
    sm = SheetMapping(ws)
    sep_idx = _find_sep_idx(ws)
    if sep_idx is None:
        print(f"{RED}Error:{NC} cannot find table separator", file=sys.stderr)
        wb.close()
        sys.exit(1)
    data_count = get_schedule_data_count(ws)
    if data_count == 0:
        print(f"{RED}Error:{NC} cannot determine data column count", file=sys.stderr)
        wb.close()
        sys.exit(1)
    B8CCE4_FILL = PatternFill(start_color="B8CCE4", end_color="B8CCE4", fill_type="solid")
    WHITE_FILL = PatternFill(start_color="FFFFFF", end_color="FFFFFF", fill_type="solid")
    OTP_FILL = PatternFill(start_color="92D050", end_color="92D050", fill_type="solid")
    t1_start = 3
    b8_total = 0
    white_total = 0
    otp_total = 0
    for r in range(t1_start, sep_idx + 1):
        for c in range(3, 3 + data_count):
            cell = sm.get_cell(r, c)
            if cell is not None and isinstance(cell.value, str) and cell.value.strip() == "ОТ":
                cell.value = "ОТП"
            if cell is not None and isinstance(cell.value, str) and cell.value.strip() == "В":
                cell.value = ""
            if cell is None or cell.value is None or (isinstance(cell.value, str) and cell.value.strip() == ""):
                sm.set_cell(r, c, fill=B8CCE4_FILL)
                b8_total += 1
            elif isinstance(cell.value, (int, float)):
                sm.set_cell(r, c, fill=WHITE_FILL)
                white_total += 1
            elif isinstance(cell.value, str) and cell.value.strip() == "ОТП":
                sm.set_cell(r, c, fill=OTP_FILL)
                otp_total += 1
    print(f"{GREEN}→{NC} Pretty: B8CCE4={b8_total} white={white_total} OTP={otp_total}", file=sys.stderr)
    first_sheet = wb.worksheets[0]
    first_name = first_sheet.title
    first_sheet.delete_rows(1, first_sheet.max_row or 1)
    sm.render(first_sheet)
    new_sep = _find_sep_idx(first_sheet)
