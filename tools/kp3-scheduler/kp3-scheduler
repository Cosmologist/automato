# Main
# ═══════════════════════════════════════════════════════════════

def main() -> None:
    print_summary()
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("args", nargs="*", default=[])
    parsed = parser.parse_args()
    if not parsed.args:
        ns = interactive_prompt()
    else:
        ns = argparse.Namespace()
        ns.mode = parsed.args[0]
    preflight(ns.mode)
    if ns.mode in ("diff"):
        step_diff()
    elif ns.mode in ("clean"):
        step_clean()
    elif ns.mode in ("merge"):
        step_merge()
    elif ns.mode in ("update"):
        step_update()
    elif ns.mode in ("pretty"):
        step_pretty()
    elif ns.mode in ("final"):
        step_final()
    elif ns.mode in ("complete"):
        step_complete()
    else:
        print(f"Unknown mode: {ns.mode}", file=sys.stderr)
        print("  Valid modes: diff, clean, merge, update, pretty, final, complete", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
